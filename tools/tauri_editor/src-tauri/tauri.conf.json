{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CDC Content Editor",
  "version": "0.1.0",
  "identifier": "com.cdcsurvival.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CDC Editor Bootstrap",
        "width": 640,
        "height": 480,
        "minWidth": 320,
        "minHeight": 240,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
