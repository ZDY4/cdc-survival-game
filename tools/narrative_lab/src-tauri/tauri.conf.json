{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CDC Narrative Lab",
  "version": "0.1.0",
  "identifier": "com.cdcsurvival.editor.narrative",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CDC Narrative Lab",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
