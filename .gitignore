.worktrees/

# Codex local workspace state
.codex/tmp/

# Local lint/cache artifacts
.gdlint
nul
__pycache__/
.pytest_cache/
.venv/

# IDE/editor settings
.vscode/
.idea/

# Common temp files
*.log
*.tmp
*.bak
*.swp
*~

# Build artifacts
*.pck
*.wasm
rust/target/
tools/tauri_editor/node_modules/
tools/tauri_editor/dist/
tools/tauri_editor/.vite/
tools/tauri_editor/src-tauri/target/
native/jps_extension/.vs/
native/jps_extension/build/
native/jps_extension/build_nmake/

