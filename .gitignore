# Godot 4+ specific ignores
.godot/
.import/
export.cfg
export_presets.cfg

# Godot resource metadata should be versioned
!*.import

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# System specific ignores
.DS_Store
Thumbs.db

# Worktrees
.worktrees/

# Local lint/cache artifacts
.gdlint
nul
__pycache__/
.pytest_cache/
.venv/

# IDE/editor settings
.vscode/
.idea/

# Common temp files
*.log
*.tmp
*.bak
*.swp
*~

# Build artifacts
*.pck
*.wasm

# Local asset backup files
*.backup

# Local Godot UID backups
.local_backup/

# Godot UID cache files should not be versioned
*.uid
